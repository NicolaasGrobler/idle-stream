---
import Layout from "../layouts/Layout.astro";
import Nav    from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { GITHUB_URL } from "../config";

const issue = (n: number) => `${GITHUB_URL}/issues/${n}`;

// Recently shipped — the closed issues. Proof the plan is real.
const shipped = [
  { n: 4, title: "External mic audio",     blurb: "USB & wireless lavaliers join as audio-only sources — mixed or swapped per section in the export." },
  { n: 3, title: "Screen as a camera",     blurb: "Share a laptop or Android screen as a full camera source through the same pipeline." },
  { n: 2, title: "Crossfade transitions",  blurb: "Optional dissolves between angles in the rendered program edit." },
];

// Planned work, grouped into tracks. `focus` highlights the live-output track.
const tracks = [
  {
    key: "live", label: "Go live", tag: "the frontier",
    lede: "Today the studio records every angle and logs the cut for post. Next: put a feed — or a whole switched program — on air.",
    focus: true,
    items: [
      { n: 20, title: "Single camera → YouTube / Facebook", blurb: "Push one source straight to an RTMP destination. No compositor, no OBS — the lightweight live tier." },
      { n: 17, title: "Switched program, live",             blurb: "Your 1-2-3 takes broadcast as one continuous stream, driven by a headless OBS the operator never sees." },
      { n: 18, title: "Pro & PTZ cameras",                  blurb: "Bring a dedicated network camera (RTSP / NDI) into the rig — not just phones and browsers." },
      { n: 19, title: "Download only what you need",         blurb: "Recording stays small and offline; live switching is a separate, optional add-on." },
    ],
  },
  {
    key: "show", label: "Run the show", tag: "operator",
    lede: "Make the booth calm enough for a volunteer who has never seen it before.",
    items: [
      { n: 6,  title: "Sunday mode",            blurb: "A single-screen wizard so a substitute can run the whole service unaided." },
      { n: 8,  title: "Always-on health strip", blurb: "Live, glanceable status that replaces the manual pre-flight button." },
      { n: 11, title: "Tally lights",           blurb: "Each device shows ON AIR when its camera is the program feed." },
      { n: 15, title: "Confidence monitor",     blurb: "A clean full-screen program output for the stage or front-of-house." },
      { n: 13, title: "Run it from a phone",    blurb: "A responsive operator view so the director isn't tied to the laptop." },
      { n: 14, title: "Mic-aware switching",    blurb: "Mics listen, and the dashboard suggests the camera of whoever's speaking." },
      { n: 10, title: "Operator lock",          blurb: "Optional passphrase + token so not everyone on the WiFi can drive the studio." },
    ],
  },
  {
    key: "post", label: "Finish in post", tag: "export",
    lede: "From the per-angle masters and the switch log to a finished deliverable.",
    items: [
      { n: 9,  title: "Markers & chapters",    blurb: "Drop markers with M while you record; carry them into the export as chapters." },
      { n: 7,  title: "Automatic transcripts", blurb: "Transcribe each session to SRT / VTT / text locally after you stop." },
      { n: 12, title: "Vertical clips",        blurb: "9:16 sermon-clip export and batch presets for social." },
      { n: 16, title: "Multi-track timeline",  blurb: "A resizable multi-track view in the session editor." },
    ],
  },
  {
    key: "everywhere", label: "Everywhere", tag: "platform",
    lede: "Run it on any machine, and make the first ten minutes effortless.",
    items: [
      { n: 1,  title: "macOS & Linux",     blurb: "Verified CLI plus a native installer and tray for Mac and Linux." },
      { n: 21, title: "Get Started guide", blurb: "A step-by-step setup walkthrough, here on the site." },
    ],
  },
];

const plannedCount = tracks.reduce((s, t) => s + t.items.length, 0);
---

<Layout
  title="Roadmap — Wireless Multicam Studio"
  description="What's shipped, what's planned, and what's being explored for Wireless Multicam Studio — the open-source, LAN-only multi-camera recording studio. Every card links to its GitHub issue."
>
  <Nav />
  <main class="bg-[#0a0a0a]">

    <!-- ============================ HERO ============================ -->
    <section class="hero">
      <canvas id="sig" class="hero-sig" aria-hidden="true"></canvas>
      <div class="hero-fade" aria-hidden="true"></div>

      <div class="hero-inner reveal-fade">
        <div class="eyebrow"><span class="idx rec-dot">●</span> Roadmap · built in the open</div>
        <h1 class="hd">What&rsquo;s on air —<br />and what&rsquo;s cued up next.</h1>
        <p class="lede">
          Wireless Multicam Studio already records every angle losslessly and logs the cut
          for post. This is everything else we&rsquo;re building — shipped, planned, and being
          explored. None of it is promised; all of it is the direction. Every card opens its
          GitHub issue.
        </p>

        <div class="stats">
          <span class="stat"><span class="d d-live"></span><b>{shipped.length}</b> shipped</span>
          <span class="stat"><span class="d d-plan"></span><b>{plannedCount}</b> planned</span>
          <a class="stat stat-link" href={`${GITHUB_URL}/issues/5`} target="_blank" rel="noopener">
            <span class="d d-explore"></span>how it&rsquo;s decided&nbsp;→
          </a>
        </div>
      </div>
    </section>

    <!-- ========================== RUNDOWN =========================== -->
    <section class="rundown-wrap">
      <div class="rundown">
        <div class="spine" aria-hidden="true"></div>

        {tracks.map((t) => (
          <div class={`track${t.focus ? " is-focus" : ""}`}>
            <span class="node" aria-hidden="true"></span>

            <header class="track-head reveal">
              <div class="track-head-row">
                <h2 class="track-label">{t.label}</h2>
                <span class="track-tag">{t.tag}</span>
              </div>
              <p class="track-lede">{t.lede}</p>
            </header>

            <div class="cards reveal">
              {t.items.map((it) => (
                <a class="card" href={issue(it.n)} target="_blank" rel="noopener" aria-label={`${it.title} — issue #${it.n} on GitHub`}>
                  <div class="card-top">
                    <span class="tally"></span>
                    <span class="card-status">Planned</span>
                    <span class="card-no">#{it.n}</span>
                  </div>
                  <h3 class="card-title">{it.title}</h3>
                  <p class="card-blurb">{it.blurb}</p>
                  <span class="card-cta">View issue&nbsp;→</span>
                </a>
              ))}
            </div>
          </div>
        ))}

        <!-- Shipped lane -->
        <div class="track is-shipped">
          <span class="node" aria-hidden="true"></span>
          <header class="track-head reveal">
            <div class="track-head-row">
              <h2 class="track-label">On air</h2>
              <span class="track-tag">already shipped</span>
            </div>
            <p class="track-lede">Recently landed and in the app today. The roadmap isn&rsquo;t a wishlist — it moves.</p>
          </header>
          <div class="cards reveal">
            {shipped.map((it) => (
              <a class="card card-shipped" href={issue(it.n)} target="_blank" rel="noopener" aria-label={`${it.title} — issue #${it.n} on GitHub (shipped)`}>
                <div class="card-top">
                  <span class="tally tally-live rec-dot"></span>
                  <span class="card-status card-status-live">Shipped</span>
                  <span class="card-no">#{it.n}</span>
                </div>
                <h3 class="card-title">{it.title}</h3>
                <p class="card-blurb">{it.blurb}</p>
                <span class="card-cta">View issue&nbsp;→</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ========================== CLOSING =========================== -->
    <section class="close">
      <div class="close-inner reveal-fade">
        <h2 class="close-hd">It&rsquo;s your studio too.</h2>
        <p class="close-sub">
          Every line of this is public. Vote with a 👍 on the issues that matter to you,
          open a new one, or send a pull request.
        </p>
        <div class="close-cta">
          <a class="btn btn-primary" href={`${GITHUB_URL}/issues`} target="_blank" rel="noopener">Browse the issues</a>
          <a class="btn btn-ghost" href={`${GITHUB_URL}/issues/new`} target="_blank" rel="noopener">Suggest a feature&nbsp;→</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ---------- shared type (mirrors features.astro) ---------- */
  .eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font: 600 11px/1 var(--font-mono); text-transform: uppercase; letter-spacing: 0.18em;
    color: var(--color-muted); margin-bottom: 22px;
  }
  .eyebrow .idx { color: var(--color-accent); font-size: 9px; }
  .hd  { color: var(--color-text); font-weight: 680; letter-spacing: -0.025em; line-height: 1.02; font-size: clamp(40px, 6.4vw, 78px); }
  .lede { margin-top: 24px; max-width: 56ch; font-size: clamp(16px, 1.5vw, 19px); line-height: 1.6; color: #aab0b9; }

  /* ----------------------- HERO ----------------------- */
  .hero {
    position: relative; isolation: isolate; overflow: clip;
    border-bottom: 1px solid #1d1f24;
    background:
      radial-gradient(120% 90% at 18% 0%, rgba(22,163,74,0.10), transparent 55%),
      var(--color-bg);
  }
  .hero-sig {
    position: absolute; inset: 0; width: 100%; height: 100%;
    z-index: -2; display: block; opacity: 0; transition: opacity 1.1s ease;
  }
  .hero-sig.is-on { opacity: 1; }
  /* fade the signal field into solid bg at the bottom so cards read cleanly */
  .hero-fade {
    position: absolute; inset: 0; z-index: -1; pointer-events: none;
    background: linear-gradient(180deg, transparent 40%, rgba(10,10,10,0.65) 78%, var(--color-bg) 100%);
  }
  .hero-inner { max-width: 1180px; margin: 0 auto; padding: clamp(84px, 13vh, 150px) 24px clamp(60px, 9vh, 96px); }
  @media (min-width: 640px) { .hero-inner { padding-left: 40px; padding-right: 40px; } }

  .stats { margin-top: 38px; display: flex; flex-wrap: wrap; align-items: center; gap: 10px 22px; }
  .stat {
    display: inline-flex; align-items: center; gap: 9px;
    font: 500 13px/1 var(--font-mono); color: var(--color-muted);
    letter-spacing: 0.02em;
  }
  .stat b { color: var(--color-text); font-weight: 700; }
  .stat-link { color: #aab0b9; text-decoration: none; transition: color .15s ease; }
  .stat-link:hover { color: var(--color-accent); }
  .d { width: 8px; height: 8px; border-radius: 50%; flex: none; }
  .d-live    { background: var(--color-accent); box-shadow: 0 0 9px rgba(74,222,128,0.65); }
  .d-plan    { background: transparent; border: 1.5px solid var(--color-faint); }
  .d-explore { background: var(--color-link); box-shadow: 0 0 9px rgba(147,197,253,0.5); }

  /* ---------------------- RUNDOWN --------------------- */
  .rundown-wrap { max-width: 1180px; margin: 0 auto; padding: clamp(56px, 8vh, 88px) 24px; }
  @media (min-width: 640px) { .rundown-wrap { padding-left: 40px; padding-right: 40px; } }

  .rundown { position: relative; }

  /* the signal spine running down the rundown, with a falling green pulse */
  .spine {
    position: absolute; left: 7px; top: 8px; bottom: 8px; width: 2px;
    background: linear-gradient(180deg, transparent, var(--color-border-2) 4%, var(--color-border-2) 96%, transparent);
    overflow: hidden; border-radius: 2px;
  }
  .spine::after {
    content: ""; position: absolute; left: 0; right: 0; height: 42%;
    background: linear-gradient(180deg, transparent, var(--color-accent), transparent);
    opacity: 0.55; filter: blur(0.3px);
    animation: spine-fall 4.8s linear infinite;
  }
  @keyframes spine-fall { from { transform: translateY(-100%); } to { transform: translateY(280%); } }
  @media (prefers-reduced-motion: reduce) { .spine::after { animation: none; opacity: 0.3; top: 30%; } }
  @media (max-width: 760px) { .spine { display: none; } }

  .track { position: relative; padding-left: 40px; }
  .track + .track { margin-top: clamp(44px, 6vh, 72px); }
  .is-shipped { margin-top: clamp(56px, 8vh, 96px); padding-top: clamp(40px, 6vh, 64px); border-top: 1px solid #17191e; }
  @media (max-width: 760px) { .track { padding-left: 0; } }

  /* node dot sitting on the spine */
  .node {
    position: absolute; left: 0; top: 5px; width: 16px; height: 16px; border-radius: 50%;
    background: var(--color-bg); border: 2px solid var(--color-border-2); z-index: 1;
  }
  .is-focus .node { border-color: var(--color-accent-dim); box-shadow: 0 0 0 4px rgba(22,163,74,0.10); }
  .is-focus .node::after {
    content: ""; position: absolute; inset: 3px; border-radius: 50%;
    background: var(--color-accent); box-shadow: 0 0 8px rgba(74,222,128,0.7);
  }
  .is-shipped .node { border-color: var(--color-accent-dim); }
  .is-shipped .node::after { content: ""; position: absolute; inset: 3px; border-radius: 50%; background: var(--color-accent); }
  @media (max-width: 760px) { .node { display: none; } }

  .track-head { margin-bottom: 20px; }
  .track-head-row { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  .track-label { color: var(--color-text); font-size: clamp(22px, 2.6vw, 30px); font-weight: 660; letter-spacing: -0.02em; }
  .is-focus .track-label { color: #eafff1; }
  .track-tag {
    font: 600 10px/1 var(--font-mono); text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--color-faint); border: 1px solid #23262c; border-radius: 999px; padding: 5px 9px;
  }
  .is-focus .track-tag { color: var(--color-accent); border-color: #1f3a2a; background: #0c1a12; }
  .track-lede { margin-top: 10px; max-width: 60ch; color: var(--color-muted); font-size: 14.5px; line-height: 1.6; }

  /* cards */
  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  @media (max-width: 900px) { .cards { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .cards { grid-template-columns: 1fr; } }

  .card {
    position: relative; display: flex; flex-direction: column; gap: 11px;
    background: #0c0d10; border: 1px solid #1f2228; border-radius: 14px;
    padding: 18px 18px 20px; text-decoration: none; overflow: hidden;
    transition: border-color .16s ease, background .16s ease, transform .16s ease;
  }
  /* faint scanline texture — broadcast feel, near-invisible */
  .card::before {
    content: ""; position: absolute; inset: 0; pointer-events: none; opacity: 0.4;
    background: repeating-linear-gradient(180deg, rgba(255,255,255,0.014) 0 1px, transparent 1px 3px);
  }
  .card:hover { border-color: #313842; background: #0e1014; transform: translateY(-2px); }
  .card:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }

  .card-top { display: flex; align-items: center; gap: 9px; }
  .tally { width: 8px; height: 8px; border-radius: 2px; background: transparent; border: 1.5px solid var(--color-faint); flex: none; }
  .tally-live { background: var(--color-rec); border-color: var(--color-rec); box-shadow: 0 0 8px rgba(239,68,68,0.6); }
  .card-status { font: 600 10px/1 var(--font-mono); text-transform: uppercase; letter-spacing: 0.14em; color: var(--color-faint); }
  .card-status-live { color: #f1a3a3; }
  .card-no { margin-left: auto; font: 600 11px/1 var(--font-mono); color: #4b515a; letter-spacing: 0.04em; }

  .card-title { color: var(--color-text); font-size: 16.5px; font-weight: 640; letter-spacing: -0.012em; line-height: 1.25; }
  .card-blurb { color: #9aa0a6; font-size: 13.5px; line-height: 1.58; flex: 1; }
  .card-cta { font: 600 12px/1 var(--font-mono); color: var(--color-faint); letter-spacing: 0.03em; transition: color .16s ease; }
  .card:hover .card-cta { color: var(--color-accent); }

  /* focus track cards get a green left-edge accent */
  .is-focus .card { border-color: #20312a; background: #0b110d; }
  .is-focus .card::after {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
    background: linear-gradient(180deg, var(--color-accent), var(--color-accent-dim)); opacity: 0.7;
  }
  .is-focus .card:hover { border-color: #2c5740; background: #0d140f; }

  .card-shipped { background: #0b0f0c; border-color: #18241b; }
  .card-shipped:hover { border-color: #234a30; background: #0c130d; }

  /* ---------------------- CLOSING --------------------- */
  .close { border-top: 1px solid #1d1f24; background: linear-gradient(180deg, var(--color-bg), #0b0d0b); }
  .close-inner { max-width: 720px; margin: 0 auto; padding: clamp(72px, 11vh, 128px) 24px; text-align: center; }
  .close-hd { color: var(--color-text); font-size: clamp(30px, 4.4vw, 50px); font-weight: 670; letter-spacing: -0.022em; }
  .close-sub { margin: 18px auto 0; max-width: 48ch; color: #aab0b9; font-size: clamp(15px, 1.4vw, 17px); line-height: 1.6; }
  .close-cta { margin-top: 32px; display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; }
  .btn { display: inline-flex; align-items: center; border-radius: 10px; font-size: 14px; font-weight: 600; padding: 11px 20px; text-decoration: none; transition: background .15s ease, border-color .15s ease, color .15s ease; }
  .btn-primary { background: var(--color-accent-2); color: #fff; }
  .btn-primary:hover { background: var(--color-accent-deep); }
  .btn-ghost { color: #c4c9d0; border: 1px solid #2c313a; }
  .btn-ghost:hover { color: var(--color-accent); border-color: #2f7d4f; }
</style>

<script>
  // Confined WebGL "signal field" behind the hero. Tasteful: a near-black field
  // with faint flowing green noise + drifting scan bands. Degrades to the CSS
  // gradient if WebGL is unavailable, and renders a single static frame under
  // reduced-motion / when the tab is hidden.
  (() => {
    const canvas = document.getElementById("sig");
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const reduce =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let gl: WebGLRenderingContext | null = null;
    try {
      gl =
        (canvas.getContext("webgl", { antialias: false, alpha: false, depth: false }) as WebGLRenderingContext | null) ||
        (canvas.getContext("experimental-webgl") as WebGLRenderingContext | null);
    } catch { gl = null; }
    if (!gl) return; // leave the CSS gradient fallback in place

    const vsrc = `attribute vec2 p; void main(){ gl_Position = vec4(p, 0.0, 1.0); }`;
    const fsrc = `
      precision mediump float;
      uniform vec2 u_res; uniform float u_time;
      float hash(vec2 p){ return fract(sin(dot(p, vec2(127.1,311.7)))*43758.5453); }
      float noise(vec2 p){
        vec2 i=floor(p), f=fract(p);
        float a=hash(i), b=hash(i+vec2(1.,0.)), c=hash(i+vec2(0.,1.)), d=hash(i+vec2(1.,1.));
        vec2 u=f*f*(3.-2.*f);
        return mix(mix(a,b,u.x), mix(c,d,u.x), u.y);
      }
      float fbm(vec2 p){ float v=0.,a=0.5; for(int i=0;i<5;i++){ v+=a*noise(p); p*=2.0; a*=0.5; } return v; }
      void main(){
        vec2 uv = gl_FragCoord.xy / u_res.xy;
        vec2 q = uv; q.x *= u_res.x / u_res.y;
        float t = u_time * 0.045;
        float n = fbm(q*2.6 + vec2(t, t*0.35));
        n += 0.45*fbm(q*5.4 - vec2(t*0.7, 0.0));
        float scan = 0.5 + 0.5*sin(uv.y*230.0 + u_time*1.4);
        scan = pow(scan, 9.0) * 0.05;
        float field = smoothstep(0.52, 1.0, n) * 0.17 + scan;
        float vig = smoothstep(1.25, 0.15, length(uv - 0.5));
        vec3 green = vec3(0.29, 0.87, 0.50);
        vec3 col = green * field * vig + vec3(0.012, 0.014, 0.016);
        gl_FragColor = vec4(col, 1.0);
      }`;

    const compile = (type: number, src: string) => {
      const s = gl!.createShader(type)!;
      gl!.shaderSource(s, src); gl!.compileShader(s);
      return s;
    };
    const prog = gl.createProgram()!;
    gl.attachShader(prog, compile(gl.VERTEX_SHADER, vsrc));
    gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, fsrc));
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) return;
    gl.useProgram(prog);

    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
    const loc = gl.getAttribLocation(prog, "p");
    gl.enableVertexAttribArray(loc);
    gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);

    const uRes = gl.getUniformLocation(prog, "u_res");
    const uTime = gl.getUniformLocation(prog, "u_time");

    const resize = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      const w = Math.floor(canvas.clientWidth * dpr);
      const h = Math.floor(canvas.clientHeight * dpr);
      if (canvas.width !== w || canvas.height !== h) {
        canvas.width = w; canvas.height = h;
        gl!.viewport(0, 0, w, h);
      }
      gl!.uniform2f(uRes, w, h);
    };

    const draw = (tMs: number) => {
      resize();
      gl!.uniform1f(uTime, tMs * 0.001);
      gl!.drawArrays(gl!.TRIANGLES, 0, 3);
    };

    canvas.classList.add("is-on");

    if (reduce) {
      draw(8200); // a pleasant static frame
      window.addEventListener("resize", () => draw(8200));
      return;
    }

    let raf = 0;
    const loop = (t: number) => { draw(t); raf = requestAnimationFrame(loop); };
    raf = requestAnimationFrame(loop);
    // pause when the tab/page isn't visible — no wasted GPU
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) { cancelAnimationFrame(raf); }
      else { raf = requestAnimationFrame(loop); }
    });
  })();
</script>
