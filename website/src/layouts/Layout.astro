---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Wireless Multicam Studio — Open-source multi-camera recording, no app install.",
  description = "Turn every phone in the room into a synchronized camera. Lossless multi-angle recording on your laptop. Open source, local, no cloud.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0b0d" />

    <link rel="icon" type="image/png" href="/icon.png" />
    <link
      rel="preconnect"
      href="https://rsms.me/"
    />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/icon.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>
