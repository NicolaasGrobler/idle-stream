---
const builtOn = [
  { name: "MediaMTX", href: "https://github.com/bluenviron/mediamtx" },
  { name: "FFmpeg",   href: "https://ffmpeg.org/" },
  { name: "mkcert",   href: "https://github.com/FiloSottile/mkcert" },
  { name: "WebRTC / WHIP", href: "https://datatracker.ietf.org/doc/draft-ietf-wish-whip/" },
];

const usedFor = [
  "Church services", "Conferences", "Theater & school plays", "Live music",
  "Sports", "Panel discussions", "Podcasts", "Interviews",
];

const lbl = "font-mono text-[11px] uppercase tracking-[0.18em] text-[#6f757e] shrink-0";
---

<section class="border-y border-[#1d1f24] bg-[#0c0d10] overflow-hidden">
  <div class="mx-auto max-w-[1240px] px-6 sm:px-10 py-8">

    <!-- Built on — label on its own line (stacked) on mobile, inline on desktop -->
    <div class="flex flex-col items-center gap-3 sm:flex-row sm:flex-wrap sm:justify-center sm:gap-3">
      <span class={lbl}>Built&nbsp;on</span>
      <div class="flex flex-wrap justify-center gap-2">
        {builtOn.map((b) => (
          <a
            href={b.href}
            class="inline-flex items-center gap-2 whitespace-nowrap rounded-[7px] border border-[#23262c] bg-[#101216] px-[11px] py-1.5 text-[13px] text-[#c4c9d0] no-underline transition-colors hover:border-[#2f7d4f] hover:text-white"
          >
            <span class="size-[7px] rounded-[2px] bg-[#4ade80] shadow-[0_0_6px_rgba(74,222,128,0.55)]"></span>{b.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Used for — label on its own line on mobile; a distinct plain-text scrolling ticker -->
    <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center sm:gap-4">
      <span class={lbl}>Used&nbsp;for</span>
      <div
        class="marquee relative w-full max-w-full overflow-hidden sm:w-auto sm:max-w-[640px]"
        style="mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);"
      >
        <div class="marquee-track flex w-max items-center whitespace-nowrap will-change-transform">
          {[...usedFor, ...usedFor].map((u) => (
            <span class="inline-flex items-center gap-2.5 px-5 text-[15px] text-[#aab0b9]">
              <span class="size-[5px] rounded-full bg-[#4ade80]/70"></span>{u}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
