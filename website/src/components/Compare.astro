---
const cols = [
  { key: "us",        label: "Multicam Studio", spec: "this project", us: true },
  { key: "obs",       label: "OBS + NDI",       spec: "software · desktop" },
  { key: "riverside", label: "Riverside",       spec: "cloud · $24/mo" },
  { key: "atem",      label: "ATEM Mini Pro",   spec: "hardware · $300+" },
];

const rows = [
  { name: "Phones as cameras",     vals: ["✓", "~setup heavy", "✓", "✗"] },
  { name: "No app install",        vals: ["✓", "✗", "✗", "—n/a"] },
  { name: "Lossless per camera",   vals: ["✓", "✓", "✗", "✗"] },
  { name: "Works fully offline",   vals: ["✓", "✓", "✗", "✓"] },
  { name: "Hardware cost",         vals: ["$0", "$0", "$0", "$300+"] },
  { name: "Monthly subscription",  vals: ["none", "none", "$24/mo", "none"] },
  { name: "Open source",           vals: ["✓ MIT", "✓ GPL", "✗", "✗"] },
];
---

<section id="compare" class="border-t border-[#1d1f24] bg-[#0c0d10]">
  <div class="mx-auto max-w-[1180px] px-6 sm:px-10 py-24 sm:py-32">

    <div class="reveal-fade mb-12 max-w-2xl">
      <div class="eyebrow"><span class="idx">02</span> Why not just use…</div>
      <h2 class="hd">The honest comparison.</h2>
      <p class="lede">
        Multicam shoots have lived in $300 hardware or $24/mo SaaS. Neither uses the
        cameras you already own. Here's what changes.
      </p>
    </div>

    <div class="reveal cmp-scroll">
      <table class="cmp">
        <thead>
          <tr>
            <th class="cap-h"><span>Capability</span></th>
            {cols.map((c) => (
              <th class={c.us ? "col-us col-us-top" : "col-h"}>
                <div class="ch-name">
                  <span class={c.us ? "dot-on" : "dot-dim"}></span>{c.label}
                </div>
                <span class={`ch-spec ${c.us ? "is-us" : ""}`}>{c.spec}</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((r, ri) => (
            <tr>
              <td class="cap"><span class="rn">{String(ri + 1).padStart(2, "0")}</span>{r.name}</td>
              {r.vals.map((v, i) => {
                const us = cols[i].us;
                const last = ri === rows.length - 1;
                return (
                  <td class={us ? `col-us${last ? " col-us-bot" : ""}` : ""} data-col={cols[i].label}>
                    {v.startsWith("✓") ? (
                      <span class="yes">
                        <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true">
                          <circle cx="12" cy="12" r="11" fill="#16351f" stroke="#2f7d4f" stroke-width="1.4"></circle>
                          <path d="M7 12.4l3.1 3.1L17 9" fill="none" stroke="#4ade80" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                        {v.length > 1 && <em>{v.slice(2)}</em>}
                      </span>
                    ) : v.startsWith("~") ? (
                      <span class="partial">{v.slice(1)}</span>
                    ) : v === "✗" ? (
                      <span class="no">—</span>
                    ) : v.startsWith("—") ? (
                      <span class="dim">{v.slice(1)}</span>
                    ) : (
                      <span class="txt">{v}</span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font: 600 11px/1 var(--font-mono); text-transform: uppercase; letter-spacing: 0.18em;
    color: #8b929c; margin-bottom: 20px;
  }
  .eyebrow .idx { color: #4ade80; border: 1px solid #1f3a2a; background: #0c1a12; border-radius: 5px; padding: 3px 6px; }
  .hd { color: #f3f4f6; font-weight: 650; letter-spacing: -0.02em; line-height: 1.04; font-size: clamp(34px, 5vw, 60px); }
  .lede { margin-top: 18px; font-size: 17px; line-height: 1.6; color: #aab0b9; }

  .cmp-scroll { overflow-x: auto; padding-top: 8px; }
  .cmp { width: 100%; min-width: 640px; border-collapse: separate; border-spacing: 0; text-align: left; }

  .cap-h { padding: 0 16px 16px 0; width: 28%; }
  .cap-h span { font: 600 11px/1 var(--font-mono); text-transform: uppercase; letter-spacing: 0.16em; color: #6f757e; }

  .col-h { padding: 0 16px 16px; vertical-align: bottom; }
  .ch-name { display: flex; align-items: center; gap: 8px; font-size: 16px; font-weight: 600; color: #cfd3da; white-space: nowrap; }
  .ch-spec { display: block; margin-top: 4px; font: 500 11px/1 var(--font-mono); color: #5b6068; }
  .ch-spec.is-us { color: #6f8f78; }
  .dot-dim { width: 7px; height: 7px; border-radius: 50%; background: #3a3f47; flex: none; }
  .dot-on { width: 7px; height: 7px; border-radius: 50%; background: #4ade80; box-shadow: 0 0 7px rgba(74,222,128,0.7); flex: none; }

  /* Winning column = a raised, glowing green program panel. */
  .col-us {
    padding: 0 16px; background: rgba(74, 222, 128, 0.05);
    border-left: 1px solid rgba(74, 222, 128, 0.22); border-right: 1px solid rgba(74, 222, 128, 0.22);
    box-shadow: 0 0 40px -12px rgba(74, 222, 128, 0.18);
  }
  .col-us-top { padding-top: 16px; padding-bottom: 16px; vertical-align: bottom; border-top: 1px solid rgba(74, 222, 128, 0.3); border-radius: 12px 12px 0 0; }
  .col-us-bot { border-bottom: 1px solid rgba(74, 222, 128, 0.3); border-radius: 0 0 12px 12px; }
  .col-us .ch-name { color: #4ade80; }

  tbody tr { transition: background .15s ease; }
  tbody tr:hover { background: rgba(255, 255, 255, 0.018); }
  .cap { padding: 14px 16px 14px 0; font-size: 15px; color: #c4c9d0; border-top: 1px solid #1c1f24; }
  .rn { font: 500 13px/1 var(--font-mono); color: #4b5159; margin-right: 12px; }
  td:not(.cap):not(.col-us) { padding: 14px 16px; font-size: 15px; color: #c4c9d0; border-top: 1px solid #1c1f24; }
  .col-us { font-size: 15px; border-top: 1px solid rgba(74,222,128,0.14); }
  .col-us.col-us-top { border-top: 1px solid rgba(74, 222, 128, 0.3); }
  .col-us .yes em, .col-us .txt { color: #d8f3e2; }

  .yes { display: inline-flex; align-items: center; gap: 8px; }
  .yes em { font-style: normal; font: 500 13px/1 var(--font-mono); color: #9aa0a6; }
  .txt { font: 500 14px/1 var(--font-mono); color: #c4c9d0; }
  .partial { font: 500 13px/1 var(--font-mono); color: #f59e0b; }
  .dim { font: 500 13px/1 var(--font-mono); color: #5b6068; }
  /* "doesn't have it" — a plain dim dash, NOT a checkbox-looking box. */
  .no { color: #4b5159; font: 500 16px/1 var(--font-mono); }

  /* ── Mobile: stack into one card per capability (no horizontal scroll) ── */
  @media (max-width: 700px) {
    .cmp-scroll { overflow: visible; }
    .cmp { min-width: 0; width: 100%; }
    .cmp thead { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
    .cmp tbody, .cmp tr, .cmp td { display: block; }
    .cmp tr {
      border: 1px solid #1f2228; border-radius: 12px; background: #0c0d10;
      padding: 4px 0; margin-bottom: 12px;
    }
    .cmp tr:hover { background: #0c0d10; }
    .cap {
      padding: 12px 14px 10px; font-size: 15px; font-weight: 600; color: #f3f4f6;
      border-top: none; border-bottom: 1px solid #1c1f24;
    }
    .rn { color: #4ade80; }
    td:not(.cap), .col-us {
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      padding: 9px 14px; border-top: none; font-size: 14px;
    }
    td:not(.cap)::before, .col-us::before {
      content: attr(data-col); font: 500 12px/1 var(--font-mono); color: #8b929c; letter-spacing: 0.02em;
    }
    /* the winning row, tinted green inside each card */
    .col-us, .col-us-top, .col-us-bot {
      background: rgba(74, 222, 128, 0.06); border: none; border-radius: 0;
      box-shadow: none; padding: 9px 14px;
    }
    .col-us::before { color: #4ade80; }
    .yes { gap: 8px; }
  }
</style>
