---
import { GITHUB_URL, DOWNLOAD_URL, getStarCount, formatStars } from "../config";

const stars = await getStarCount();

const links = [
  { label: "How it works", href: "/#how-it-works" },
  { label: "Features",     href: "/features" },
  { label: "Roadmap",      href: "/roadmap" },
  { label: "Compare",      href: "/#compare" },
  { label: "Docs",         href: `${GITHUB_URL}/blob/main/README.md` },
];
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-[#0a0a0a]/85 border-b border-[#1d1f24]">
  <nav class="mx-auto max-w-[1240px] flex items-center justify-between gap-4 px-6 sm:px-10 py-3.5">

    <a href="/" class="flex items-center gap-2.5 group shrink-0">
      <img src="/icon.png" alt="" width="26" height="26" class="rounded-[5px]" />
      <span class="hidden sm:inline-block text-[16px] font-semibold tracking-[-0.01em] leading-none text-[#f4f5f7]">
        Wireless Multicam Studio
      </span>
    </a>

    <div class="hidden md:flex items-center gap-8 text-[14px] text-[#aab0b9]">
      {links.map((l) => <a href={l.href} class="hover:text-[#4ade80] transition-colors">{l.label}</a>)}
    </div>

    <div class="flex items-center gap-3 sm:gap-5">
      <a
        href={GITHUB_URL}
        aria-label="GitHub repository"
        class="hidden sm:inline-flex items-center gap-2 text-[#c4c9d0] hover:text-[#4ade80] transition-colors"
      >
        <svg width="19" height="19" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
        </svg>
        {stars !== null && stars > 0 && <span class="text-[13px] text-[#8b929c] tabular-nums">★ {formatStars(stars)}</span>}
      </a>
      <a
        href={DOWNLOAD_URL}
        class="inline-flex items-center gap-2 rounded-lg bg-[#16a34a] px-3.5 py-1.5 text-[13px] font-semibold text-white hover:bg-[#15913f] transition-colors"
      >
        Download
      </a>
      <button
        type="button" data-menu-btn aria-label="Open menu" aria-expanded="false"
        class="md:hidden inline-flex items-center justify-center size-9 -mr-1 rounded-lg text-[#c4c9d0] hover:text-white hover:bg-white/5 transition-colors"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div class="md:hidden hidden border-t border-[#1d1f24] bg-[#0a0a0a]" data-menu>
    <div class="px-6 py-2 flex flex-col">
      {links.map((l) => (
        <a href={l.href} class="py-3 text-[15px] text-[#c4c9d0] border-b border-[#16181c] last:border-0 hover:text-[#4ade80] transition-colors">{l.label}</a>
      ))}
      <a href={GITHUB_URL} class="py-3 inline-flex items-center gap-2 text-[15px] text-[#c4c9d0] hover:text-[#4ade80] transition-colors">
        <svg width="17" height="17" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
        GitHub{stars !== null && stars > 0 ? ` · ★ ${formatStars(stars)}` : ""}
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.querySelector("[data-menu-btn]");
  const menu = document.querySelector("[data-menu]");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const nowOpen = menu.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(nowOpen));
    });
    menu.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        menu.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      }),
    );
  }
</script>
