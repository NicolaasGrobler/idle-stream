---
// Step 4 — a faux timeline showing the switch log + export controls.
---

<div class="rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-panel)] p-4 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
  <div class="flex items-center justify-between mb-3 text-[11px] font-mono">
    <span class="text-[color:var(--color-muted)]">SESSION 2026-05-28-19-22-04</span>
    <span class="text-[color:var(--color-accent)]">switches.json</span>
  </div>

  <!-- Timeline lanes -->
  <div class="space-y-1.5">
    {[
      { label: "CAM 1", segs: [{ from: 0,  to: 18 }, { from: 42, to: 70 }, { from: 88, to: 100 }] },
      { label: "CAM 2", segs: [{ from: 18, to: 42 }] },
      { label: "CAM 3", segs: [{ from: 70, to: 88 }] },
      { label: "MIC 1", segs: [{ from: 0,  to: 100, audio: true }] },
    ].map((lane) => (
      <div class="flex items-center gap-3">
        <span class="w-14 text-[10px] font-mono text-[color:var(--color-muted)]">{lane.label}</span>
        <div class="relative flex-1 h-5 rounded bg-[color:var(--color-bg)] border border-[color:var(--color-border)] overflow-hidden">
          {lane.segs.map((s) => (
            <div
              class={`absolute top-0 bottom-0 ${
                s.audio
                  ? "bg-[color:var(--color-accent)]/15 border-x border-[color:var(--color-accent)]/40"
                  : "bg-[color:var(--color-accent)]/60"
              }`}
              style={`left:${s.from}%; width:${s.to - s.from}%`}
            ></div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- Program edit row -->
  <div class="mt-3 flex items-center gap-3">
    <span class="w-14 text-[10px] font-mono uppercase tracking-wider text-[color:var(--color-rec)]">Program</span>
    <div class="relative flex-1 h-7 rounded bg-[color:var(--color-bg)] border border-[color:var(--color-rec)]/30 overflow-hidden">
      <div class="absolute inset-y-0 left-0 w-[18%] bg-[color:var(--color-accent)]/60 flex items-center justify-center text-[9px] font-mono text-[#04140a] font-bold">1</div>
      <div class="absolute inset-y-0 left-[18%] w-[24%] bg-[#60a5fa]/60 flex items-center justify-center text-[9px] font-mono text-black font-bold">2</div>
      <div class="absolute inset-y-0 left-[42%] w-[28%] bg-[color:var(--color-accent)]/60 flex items-center justify-center text-[9px] font-mono text-[#04140a] font-bold">1</div>
      <div class="absolute inset-y-0 left-[70%] w-[18%] bg-[#fbbf24]/60 flex items-center justify-center text-[9px] font-mono text-black font-bold">3</div>
      <div class="absolute inset-y-0 left-[88%] w-[12%] bg-[color:var(--color-accent)]/60 flex items-center justify-center text-[9px] font-mono text-[#04140a] font-bold">1</div>
    </div>
  </div>

  <div class="mt-4 flex items-center justify-between rounded-md bg-[color:var(--color-bg)] border border-[color:var(--color-border)] px-3 py-2">
    <span class="text-[11px] font-mono text-[color:var(--color-muted)]">
      Export → <span class="text-white/90">session.mp4</span> · 1080p30 · NVENC · crossfade 0.3s
    </span>
    <button class="rounded-md bg-[color:var(--color-accent)] px-2.5 py-1 text-[11px] font-semibold text-[#04140a]">
      Render
    </button>
  </div>
</div>
