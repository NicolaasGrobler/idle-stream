---
// Step 4 — the program edit: the real take sequence as a filmstrip of frames
// in cut order, the current take ringed red (PGM). Content only.
const takes = [
  { file: "stage",     cam: 1, t: "00:00" },
  { file: "closeup",   cam: 3, t: "00:18" },
  { file: "podium",    cam: 2, t: "00:42" },
  { file: "sidestage", cam: 6, t: "01:10" },
  { file: "stage",     cam: 1, t: "01:28" },
];
---

<div class="sc">
  <div class="sc-head">
    <span class="sc-label">PROGRAM · take sequence</span>
    <span class="sc-meta">switches.json</span>
  </div>
  <div class="sc-strip">
    {takes.map((tk, i) => (
      <div class={`sc-frame${i === takes.length - 1 ? " pgm" : ""}`}>
        <img src={`/feeds/cam-${tk.file}.jpg`} alt="" decoding="async" loading="lazy" />
        <span class="sc-num">{i + 1}</span>
        <span class="sc-cam">CAM {tk.cam}</span>
        {i === takes.length - 1 && <span class="sc-pgm">PGM</span>}
      </div>
    ))}
  </div>
  <div class="sc-export">
    <span class="sc-exp-txt">Export → <b>session.mp4</b> · 1080p30 · NVENC · crossfade 0.3s</span>
    <span class="sc-render">Render</span>
  </div>
</div>

<style>
  .sc { padding: 10px; }
  .sc-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; padding: 0 2px; }
  .sc-label { font: 600 10px/1 var(--font-mono); text-transform: uppercase; letter-spacing: 0.12em; color: #8b929c; }
  .sc-meta { font: 500 10px/1 var(--font-mono); color: #4ade80; }
  .sc-strip { display: flex; gap: 6px; align-items: stretch; }
  .sc-frame {
    position: relative; flex: 1; aspect-ratio: 4 / 3; border-radius: 6px; overflow: hidden;
    border: 1px solid #23262c; background: #050608;
  }
  .sc-frame.pgm { border-color: #ef4444; box-shadow: 0 0 0 1px #ef4444 inset, 0 0 16px rgba(239, 68, 68, 0.45); }
  .sc-frame img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .sc-num {
    position: absolute; top: 4px; left: 4px; font: 700 10px/1 var(--font-mono); color: #04140a;
    background: #4ade80; border-radius: 3px; padding: 2px 5px;
  }
  .sc-frame.pgm .sc-num { color: #fff; background: #dc2626; }
  .sc-cam {
    position: absolute; bottom: 4px; left: 4px; font: 600 8px/1 var(--font-mono); color: #fff;
    background: rgba(0,0,0,0.55); border-radius: 3px; padding: 2px 4px;
  }
  .sc-pgm {
    position: absolute; top: 4px; right: 4px; font: 700 8px/1 var(--font-mono); letter-spacing: 0.06em;
    color: #fff; background: #dc2626; border-radius: 3px; padding: 2px 5px;
  }
  .sc-export {
    margin-top: 10px; display: flex; align-items: center; justify-content: space-between; gap: 10px;
    padding: 9px 10px; border-radius: 7px; background: #0c0d10; border: 1px solid #1f2228;
  }
  .sc-exp-txt { font: 500 11px/1.3 var(--font-mono); color: #8b929c; }
  .sc-exp-txt b { color: #d4d8de; font-weight: 600; }
  .sc-render { font: 600 11px/1 var(--font-sans); color: #04140a; background: #4ade80; border-radius: 6px; padding: 6px 11px; }
</style>
