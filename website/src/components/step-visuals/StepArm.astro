---
// Step 2 — the operator preview: the hero's live grid, every camera armed
// (green) but NOT yet recording (no red program ring). Real venue stills.
const cams = [
  { n: 1, label: "STAGE",      file: "stage" },
  { n: 2, label: "PODIUM",     file: "podium" },
  { n: 3, label: "CLOSE-UP",   file: "closeup" },
  { n: 4, label: "SCREEN",     file: "screen" },
  { n: 5, label: "AUDIENCE",   file: "audience" },
  { n: 6, label: "SIDE STAGE", file: "sidestage" },
];
---

<div class="sa">
  <div class="sa-grid">
    {cams.map((c) => (
      <div class="sa-tile">
        <img src={`/feeds/cam-${c.file}.jpg`} alt="" decoding="async" loading="lazy" />
        <span class="sa-grad"></span>
        <span class="sa-label">{c.n} · {c.label}</span>
        <span class="sa-state"><span class="sa-dot"></span>armed</span>
      </div>
    ))}
  </div>
  <div class="sa-foot">
    <span class="sa-count"><span class="sa-dot"></span>6 cams armed · 0 recording</span>
    <span class="sa-btn">Start Recording</span>
  </div>
</div>

<style>
  .sa { padding: 10px; }
  .sa-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
  .sa-tile {
    position: relative; aspect-ratio: 16 / 9; border-radius: 7px; overflow: hidden;
    background: #050608; border: 1px solid #2f7d4f;
    box-shadow: 0 0 0 1px rgba(74, 222, 128, 0.08) inset;
  }
  .sa-tile img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .sa-grad { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 30%, transparent 64%, rgba(0,0,0,0.55) 100%); }
  .sa-label {
    position: absolute; top: 5px; left: 5px; font: 600 9px/1 var(--font-sans); color: #fff;
    padding: 2px 5px; background: rgba(0,0,0,0.5); border-radius: 4px; letter-spacing: 0.01em;
  }
  .sa-state {
    position: absolute; bottom: 5px; left: 5px; display: inline-flex; align-items: center; gap: 4px;
    font: 600 9px/1 var(--font-sans); color: #b6f3cd; padding: 2px 5px;
    background: rgba(5,30,16,0.6); border-radius: 4px;
  }
  .sa-dot { width: 5px; height: 5px; border-radius: 50%; background: #4ade80; box-shadow: 0 0 5px rgba(74,222,128,0.6); }
  .sa-foot {
    margin-top: 8px; display: flex; align-items: center; justify-content: space-between; gap: 10px;
    padding: 2px 2px 0;
  }
  .sa-count { display: inline-flex; align-items: center; gap: 6px; font: 600 11px/1 var(--font-mono); color: #9aa0a6; }
  .sa-btn {
    font: 600 11px/1 var(--font-sans); color: #fff; background: #16a34a; border-radius: 6px; padding: 6px 10px;
  }
</style>
