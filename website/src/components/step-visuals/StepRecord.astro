---
// Step 3 — recordings: a filmstrip of the real per-camera frames over the
// lossless file listing. Content only; MonitorFrame supplies the chrome.
const strip = ["stage", "podium", "closeup", "screen", "audience", "sidestage"];
const rows = [
  ["cam1/2026-05-28-19-22-04.mp4", "H.264 + Opus", "412 MB"],
  ["cam2/2026-05-28-19-22-04.mp4", "H.264 + Opus", "398 MB"],
  ["cam3/2026-05-28-19-22-04.mp4", "H.264 + Opus", "344 MB"],
  ["cam4/2026-05-28-19-22-04.mp4", "H.264 + Opus", "287 MB"],
  ["mic1/2026-05-28-19-22-04.mp4", "Opus",         "12 MB"],
];
---

<div class="sr">
  <div class="sr-strip">
    {strip.map((f, i) => (
      <div class="sr-thumb">
        <img src={`/feeds/cam-${f}.jpg`} alt="" decoding="async" loading="lazy" />
        <span class="sr-cam">{i + 1}</span>
      </div>
    ))}
  </div>
  <table class="sr-table">
    <thead>
      <tr><th>File</th><th>Codec</th><th class="r">Size</th></tr>
    </thead>
    <tbody>
      {rows.map(([file, codec, size]) => (
        <tr><td class="f">{file}</td><td class="c">{codec}</td><td class="r">{size}</td></tr>
      ))}
    </tbody>
  </table>
  <div class="sr-foot">Copy-only · no re-encoding · original quality preserved</div>
</div>

<style>
  .sr-strip { display: flex; gap: 5px; padding: 10px 10px 0; }
  .sr-thumb {
    position: relative; flex: 1; aspect-ratio: 16 / 9; border-radius: 5px; overflow: hidden;
    border: 1px solid #23262c; background: #050608;
  }
  .sr-thumb img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .sr-cam {
    position: absolute; top: 3px; left: 3px; font: 600 8px/1 var(--font-mono); color: #fff;
    background: rgba(0,0,0,0.55); border-radius: 3px; padding: 1px 4px;
  }
  .sr-table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 12px; margin-top: 10px; }
  .sr-table th {
    text-align: left; font: 600 9px/1 var(--font-mono); text-transform: uppercase; letter-spacing: 0.1em;
    color: #6f757e; padding: 6px 12px; border-bottom: 1px solid #1f2228; font-weight: 600;
  }
  .sr-table th.r, .sr-table td.r { text-align: right; }
  .sr-table td { padding: 6px 12px; border-bottom: 1px solid #16181c; color: #c4c9d0; }
  .sr-table tr:last-child td { border-bottom: none; }
  .sr-table td.c { color: #8b929c; }
  .sr-table td.r { color: #9aa0a6; font-variant-numeric: tabular-nums; }
  .sr-foot {
    font: 500 11px/1 var(--font-mono); color: #6f757e; padding: 9px 12px;
    border-top: 1px solid #1f2228; background: #0c0d10;
  }
</style>
