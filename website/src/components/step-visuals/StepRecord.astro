---
// Step 3 — a faux "recordings folder" listing showing per-cam lossless files.
---

<div class="rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-panel)] overflow-hidden shadow-[0_30px_80px_-30px_rgba(0,0,0,0.6)]">
  <div class="flex items-center gap-3 border-b border-[color:var(--color-border)] bg-[color:var(--color-panel-2)] px-4 py-2.5">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[color:var(--color-muted)]" aria-hidden="true">
      <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Z"/>
    </svg>
    <span class="text-[11px] font-mono text-[color:var(--color-muted)]">recordings/</span>
    <span class="ml-auto flex items-center gap-1.5 text-[11px] text-[color:var(--color-rec)]">
      <span class="size-1.5 rounded-full bg-[color:var(--color-rec)] rec-dot"></span>
      Recording · CPU 3%
    </span>
  </div>
  <table class="w-full text-[12px] font-mono">
    <thead class="text-[color:var(--color-muted)] uppercase text-[10px]">
      <tr class="border-b border-[color:var(--color-border)]">
        <th class="text-left px-4 py-2 font-medium tracking-wider">File</th>
        <th class="text-left px-4 py-2 font-medium tracking-wider">Codec</th>
        <th class="text-right px-4 py-2 font-medium tracking-wider">Size</th>
      </tr>
    </thead>
    <tbody class="text-[color:var(--color-text)]/85">
      {[
        ["cam1/2026-05-28-19-22-04.mp4", "H.264 + Opus", "412 MB"],
        ["cam2/2026-05-28-19-22-04.mp4", "H.264 + Opus", "398 MB"],
        ["cam3/2026-05-28-19-22-04.mp4", "H.264 + Opus", "344 MB"],
        ["cam4/2026-05-28-19-22-04.mp4", "H.264 + Opus", "287 MB"],
        ["mic1/2026-05-28-19-22-04.mp4", "Opus",          "12 MB"],
      ].map(([file, codec, size]) => (
        <tr class="border-b border-[color:var(--color-border)] last:border-0">
          <td class="px-4 py-2">{file}</td>
          <td class="px-4 py-2 text-[color:var(--color-muted)]">{codec}</td>
          <td class="px-4 py-2 text-right">{size}</td>
        </tr>
      ))}
    </tbody>
  </table>
  <div class="border-t border-[color:var(--color-border)] bg-[color:var(--color-bg)] px-4 py-2 text-[11px] text-[color:var(--color-muted)] font-mono">
    Copy-only · no re-encoding · original quality preserved
  </div>
</div>
