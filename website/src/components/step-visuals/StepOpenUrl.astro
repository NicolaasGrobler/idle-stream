---
// Step 1 placeholder — replace with a screen recording of the device page (phone)
// once you have one. File would go in public/demos/step-01-open-url.mp4 and be
// wrapped in a phone frame here.
---

<div class="relative mx-auto w-full max-w-sm">
  <!-- Phone frame -->
  <div class="aspect-[9/19.5] rounded-[36px] border border-[color:var(--color-border)] bg-[color:var(--color-panel)] p-2 shadow-[0_30px_80px_-30px_rgba(0,0,0,0.7)]">
    <div class="size-full rounded-[28px] bg-[color:var(--color-bg)] overflow-hidden flex flex-col">
      <!-- Notch -->
      <div class="h-7 flex items-center justify-center">
        <div class="h-1 w-16 rounded-full bg-black"></div>
      </div>
      <!-- URL bar -->
      <div class="px-3 py-2 border-b border-[color:var(--color-border)]">
        <div class="flex items-center gap-2 rounded-md bg-[color:var(--color-panel-2)] px-2.5 py-1.5 text-[11px] font-mono text-[color:var(--color-muted)]">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <span>192.168.1.42:8443</span>
        </div>
      </div>
      <!-- Page content -->
      <div class="flex-1 flex flex-col items-center justify-center px-5 text-center gap-5">
        <img src="/icon.png" alt="" width="56" height="56" class="rounded-xl" />
        <div>
          <div class="text-[11px] uppercase tracking-wider text-[color:var(--color-muted)]">Join as</div>
          <div class="mt-1 text-base font-semibold text-white">Stage Left Cam</div>
        </div>
        <div class="w-full space-y-2">
          <div class="rounded-md bg-[color:var(--color-accent)]/10 border border-[color:var(--color-accent)]/40 px-3 py-2 text-left">
            <div class="text-[10px] uppercase tracking-wider text-[color:var(--color-accent)]">Source</div>
            <div class="text-[13px] text-white">Back camera · 1080p</div>
          </div>
          <div class="rounded-md bg-[color:var(--color-panel-2)] border border-[color:var(--color-border)] px-3 py-2 text-left">
            <div class="text-[10px] uppercase tracking-wider text-[color:var(--color-muted)]">Or</div>
            <div class="text-[12px] text-[color:var(--color-muted)]">Screen share · Audio-only</div>
          </div>
        </div>
        <button class="w-full rounded-md bg-[color:var(--color-accent)] py-2.5 text-sm font-semibold text-[#04140a]">
          Join
        </button>
      </div>
    </div>
  </div>
</div>
