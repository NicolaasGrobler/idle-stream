---
import StepOpenUrl  from "./step-visuals/StepOpenUrl.astro";
import StepArm      from "./step-visuals/StepArm.astro";
import StepRecord   from "./step-visuals/StepRecord.astro";
import StepCut      from "./step-visuals/StepCut.astro";

const steps = [
  {
    n: "01",
    title: "Open a URL.",
    body: "Devices join from any phone or laptop browser. No App Store, no IPA, no APK. Camera, screen share, or audio-only — your call.",
    visual: "open-url",
  },
  {
    n: "02",
    title: "Arm & frame.",
    body: "Every assigned camera streams live to your laptop over the LAN. Frame every angle in the live grid before you commit to record.",
    visual: "arm",
  },
  {
    n: "03",
    title: "Record losslessly.",
    body: "Every angle records copy-only — no re-encoding. Near-zero CPU on the laptop. The phones do the work.",
    visual: "record",
  },
  {
    n: "04",
    title: "Cut in post.",
    body: "Press 1–9 to mark the program take while you record. Export the program edit as one MP4, or keep the per-angle masters.",
    visual: "cut",
  },
];
---

<section id="how-it-works" class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
  <div class="mb-16 max-w-2xl">
    <div class="text-[11px] uppercase tracking-[0.18em] text-[color:var(--color-accent)] mb-3">
      How it works
    </div>
    <h2 class="text-4xl sm:text-5xl font-semibold tracking-tight text-white leading-[1.05]">
      Four steps from phones to a finished cut.
    </h2>
  </div>

  <div class="space-y-24 sm:space-y-32">
    {steps.map((s, i) => (
      <div class={`grid items-center gap-10 md:grid-cols-2 ${i % 2 === 1 ? "md:[&>*:first-child]:order-2" : ""}`}>
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="font-mono text-[12px] text-[color:var(--color-muted)]">{s.n}</span>
            <span class="h-px flex-1 bg-[color:var(--color-border)] max-w-[80px]"></span>
          </div>
          <h3 class="text-3xl sm:text-4xl font-semibold tracking-tight text-white leading-[1.1]">
            {s.title}
          </h3>
          <p class="mt-5 text-[16px] leading-relaxed text-[color:var(--color-muted)] max-w-md">
            {s.body}
          </p>
        </div>
        <div>
          {s.visual === "open-url" && <StepOpenUrl />}
          {s.visual === "arm"      && <StepArm />}
          {s.visual === "record"   && <StepRecord />}
          {s.visual === "cut"      && <StepCut />}
        </div>
      </div>
    ))}
  </div>
</section>
