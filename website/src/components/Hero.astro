---
import DashboardMock from "./DashboardMock.astro";
import {
  GITHUB_URL,
  DOWNLOAD_URL,
  getStarCount,
  formatStars,
} from "../config";

const stars = await getStarCount();
---

<section class="relative overflow-hidden">
  <!-- Subtle green glow behind the hero -->
  <div
    class="pointer-events-none absolute inset-x-0 -top-40 h-[480px] opacity-[0.18]"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(74,222,128,0.55), transparent 60%);"
  ></div>

  <div class="mx-auto max-w-6xl px-6 pt-16 pb-12 sm:pt-24 sm:pb-16 relative">
    <!-- Eyebrow positioning pill — left-aligned with the headline -->
    <a
      href={GITHUB_URL}
      class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-panel)] px-3 py-1 text-[11px] text-[color:var(--color-muted)] hover:text-white hover:border-white/30 transition"
    >
      <span class="size-1.5 rounded-full bg-[color:var(--color-accent)]"></span>
      <span class="uppercase tracking-[0.14em]">Open source · Local · No cloud</span>
      <span aria-hidden="true">→</span>
    </a>

    <h1
      class="mt-6 text-[44px] sm:text-[64px] leading-[1.02] font-semibold tracking-[-0.025em] text-white max-w-4xl"
    >
      Turn every phone in the room
      <br class="hidden sm:block" />
      into a <span class="text-[color:var(--color-accent)]">synchronized camera</span>.
    </h1>

    <p class="mt-6 max-w-2xl text-[17px] leading-relaxed text-[color:var(--color-muted)]">
      Lossless multi-angle recording on your laptop. No app install. No capture card.
      No subscription. Just a URL.
    </p>

    <!-- Source pills (Riverside-style row under the subhead) -->
    <div class="mt-5 flex flex-wrap gap-2 text-[12px]">
      {["Camera", "Screen share", "External mic", "Webcam"].map((label, i) => (
        <span class="inline-flex items-center gap-1.5 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-panel)] px-2.5 py-1 text-[color:var(--color-muted)]">
          <span class={`size-1.5 rounded-full ${i === 0 ? "bg-[color:var(--color-accent)]" : "bg-[color:var(--color-faint)]"}`}></span>
          {label}
        </span>
      ))}
    </div>

    <!-- CTAs -->
    <div class="mt-8 flex flex-col sm:flex-row gap-3">
      <a
        href={DOWNLOAD_URL}
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-[color:var(--color-accent)] px-5 py-3 text-sm font-semibold text-[#04140a] hover:brightness-110 transition shadow-[0_8px_24px_-8px_rgba(74,222,128,0.4)]"
      >
        Download for Windows
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 5v14"/><path d="m19 12-7 7-7-7"/>
        </svg>
      </a>
      <a
        href={GITHUB_URL}
        class="inline-flex items-center justify-center gap-2 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-panel)] px-5 py-3 text-sm font-semibold text-white hover:border-white/40 transition"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5A11.5 11.5 0 0 0 .5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11.06 11.06 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.73.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.26 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/>
        </svg>
        View on GitHub
        {stars !== null && stars > 0 && (
          <span class="text-[color:var(--color-muted)] font-mono text-[12px]">★ {formatStars(stars)}</span>
        )}
      </a>
    </div>

    <p class="mt-3 text-[11px] text-[color:var(--color-faint)]">
      Free · MIT licensed · Windows installer · macOS & Linux on the way
    </p>

    <!-- Hero visual -->
    <div class="mt-14 relative">
      <DashboardMock />
    </div>
  </div>
</section>
