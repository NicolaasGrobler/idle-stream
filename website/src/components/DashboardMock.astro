---
// Stylized mock of the operator dashboard — used as the hero visual.
// Replace with a real <video autoplay muted loop playsinline> pointing at
// public/demos/operator-dashboard.mp4 once you record the dashboard.
//
// The mock intentionally uses placeholder camera labels and an obvious
// "demo" aesthetic so it doesn't get mistaken for stock photography.

const tiles = [
  { num: 1, label: "PHONE — STAGE LEFT", live: true,  active: true },
  { num: 2, label: "PHONE — WIDE",        live: true,  active: false },
  { num: 3, label: "WEBCAM — CLOSE-UP",   live: true,  active: false },
  { num: 4, label: "SCREEN SHARE",        live: true,  active: false },
];
---

<div
  class="relative w-full overflow-hidden rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-panel)] shadow-[0_30px_120px_-30px_rgba(0,0,0,0.7)]"
>
  <!-- Faux window chrome -->
  <div
    class="flex items-center gap-3 border-b border-[color:var(--color-border)] bg-[color:var(--color-panel-2)] px-4 py-2.5"
  >
    <div class="flex gap-1.5">
      <span class="size-2.5 rounded-full bg-[#3a3d44]"></span>
      <span class="size-2.5 rounded-full bg-[#3a3d44]"></span>
      <span class="size-2.5 rounded-full bg-[#3a3d44]"></span>
    </div>
    <div class="text-[11px] text-[color:var(--color-muted)] font-mono">
      studio.localhost — Operator Dashboard
    </div>
    <div class="ml-auto flex items-center gap-2 text-[11px]">
      <span class="flex items-center gap-1.5 rounded-full bg-[color:var(--color-rec)]/15 border border-[color:var(--color-rec)]/40 px-2 py-0.5 text-[color:var(--color-rec)]">
        <span class="size-1.5 rounded-full bg-[color:var(--color-rec)] rec-dot"></span>
        REC 00:42
      </span>
      <span class="text-[color:var(--color-muted)] font-mono">4 cams · 1 mic</span>
    </div>
  </div>

  <!-- 2x2 live grid -->
  <div class="grid grid-cols-2 gap-2 p-3 bg-[color:var(--color-bg)]">
    {tiles.map((t) => (
      <div
        class={`relative aspect-video rounded-lg overflow-hidden border ${
          t.active
            ? "border-[color:var(--color-accent)] shadow-[0_0_0_3px_rgba(74,222,128,0.15)]"
            : "border-[color:var(--color-border)]"
        } bg-gradient-to-br from-[#1a1d22] via-[#0e1014] to-[#1a1d22]`}
      >
        <!-- Faux "frame" content using soft gradients so it reads as video -->
        <div class="absolute inset-0 opacity-60 bg-[radial-gradient(ellipse_at_30%_30%,rgba(74,222,128,0.18),transparent_60%),radial-gradient(ellipse_at_70%_70%,rgba(99,102,241,0.18),transparent_55%)]"></div>

        <!-- Top-left LIVE pill -->
        <div class="absolute left-2 top-2 flex items-center gap-1.5 rounded-md bg-black/55 backdrop-blur px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wider text-[color:var(--color-accent)] border border-[color:var(--color-accent)]/30">
          <span class="size-1.5 rounded-full bg-[color:var(--color-accent)]"></span>
          live
        </div>

        <!-- Big take number when active, small label always -->
        {t.active && (
          <div class="absolute right-2 top-2 rounded-md bg-[color:var(--color-accent)]/95 px-1.5 py-0.5 text-[10px] font-bold text-[#04140a]">
            ON PGM
          </div>
        )}

        <div class="absolute bottom-2 left-2 right-2 flex items-center justify-between text-[10px] font-mono">
          <span class="text-white/85 truncate">
            <span class="text-[color:var(--color-muted)]">{t.num}/</span>{t.label}
          </span>
          <span class="text-[color:var(--color-muted)]">1080p · H.264</span>
        </div>
      </div>
    ))}
  </div>

  <!-- Switch log strip -->
  <div class="border-t border-[color:var(--color-border)] bg-[color:var(--color-panel-2)] px-4 py-2.5 flex items-center gap-3 text-[11px] font-mono">
    <span class="text-[color:var(--color-muted)] uppercase tracking-wider">Takes</span>
    <span class="text-white/85">
      <span class="opacity-50">00:12</span> CAM 2
      <span class="text-[color:var(--color-muted)] mx-1.5">→</span>
      <span class="opacity-50">00:24</span> CAM 1
      <span class="text-[color:var(--color-muted)] mx-1.5">→</span>
      <span class="opacity-50">00:37</span> CAM 3
      <span class="text-[color:var(--color-muted)] mx-1.5">→</span>
      <span class="opacity-50">00:42</span> <span class="text-[color:var(--color-accent)]">CAM 1</span>
    </span>
    <span class="ml-auto text-[color:var(--color-muted)]">Press 1–9 to switch</span>
  </div>
</div>
