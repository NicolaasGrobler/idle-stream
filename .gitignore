# Certs & secrets (never commit)
certs/
*.pem
*.key

# Downloaded binaries (re-fetch with setup/fetch-tools.ps1)
tools/

# Recordings
recordings/

# Rendered session exports (re-generated on demand)
exports/

# Backups (moved-out recordings + session logs)
backups/

# Runtime logs
logs/

# Operator's persisted camera config (environment-specific)
data/

# Generated MediaMTX config (rendered per-network by dev-up.ps1)
mediamtx/mediamtx.gen.yml

# Playwright MCP artifacts
.playwright-mcp/

# Node
node_modules/
dist/

# Built single-exe (regenerate with npm run build:exe)
/multicam
/multicam.exe
.vite/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
