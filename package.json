{
  "name": "wireless-multicam-studio",
  "version": "0.1.0",
  "description": "Turn phones into a synchronized multi-angle recording rig over your LAN.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "bin": {
    "multicam": "cli/index.mjs"
  },
  "scripts": {
    "setup": "node cli/index.mjs tools",
    "certs": "node cli/index.mjs certs",
    "up": "node cli/index.mjs up",
    "down": "node cli/index.mjs down",
    "build:bundle": "node build/build-sea.mjs --bundle-only",
    "build:exe": "node build/build-sea.mjs",
    "build:installer": "node build/build-installer.mjs",
    "test": "node --test control/test/control.test.mjs control/test/export.test.mjs control/test/http-range.test.mjs"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "innosetup-compiler": "^6.3.1",
    "png-to-ico": "^3.0.1",
    "postject": "^1.0.0-alpha.6",
    "qrcode-generator": "^2.0.4",
    "resedit": "^3.0.2"
  }
}
